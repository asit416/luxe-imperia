<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}
  <title>
    {%- if request.page_type == 'index' -%}
      {{ shop.name }} — {{ shop.description | default: 'Luxury Fashion House' }}
    {%- else -%}
      {{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-black:#0a0a0a;--color-white:#fafaf8;--color-cream:#f5f2ec;
      --color-warm-grey:#e8e4de;--color-mid-grey:#9a9590;--color-gold:#b8a98a;
      --color-gold-light:#d4c4a8;--color-text:#1a1a1a;--color-text-muted:#6b6560;
      --font-serif:'Cormorant Garamond','Times New Roman',serif;
      --font-sans:'Montserrat','Helvetica Neue',sans-serif;
      --header-height:60px;--max-width:1440px;
      --ease-luxury:cubic-bezier(0.25,0.46,0.45,0.94);
      --transition-slow:0.6s var(--ease-luxury);
      --transition-med:0.35s var(--ease-luxury);
      --transition-fast:0.2s var(--ease-luxury);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased;}
    body{font-family:var(--font-sans);font-weight:300;font-size:13px;letter-spacing:0.06em;color:var(--color-text);background-color:var(--color-white);overflow-x:hidden;}
    body.nav-open{overflow:hidden;}
    ::-webkit-scrollbar{width:3px;}::-webkit-scrollbar-track{background:var(--color-cream);}::-webkit-scrollbar-thumb{background:var(--color-gold);}
    h1,h2,h3,h4{font-family:var(--font-serif);font-weight:300;line-height:1.15;letter-spacing:0.02em;}
    p{line-height:1.8;font-weight:300;}
    a{color:inherit;text-decoration:none;transition:opacity var(--transition-fast);}
    a:hover{opacity:0.65;}
    img{max-width:100%;height:auto;display:block;}
    button{cursor:pointer;border:none;background:none;font-family:inherit;}
    .visually-hidden{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;}
    .container{max-width:var(--max-width);margin:0 auto;padding:0 48px;}
    .btn-luxury{display:inline-block;padding:14px 40px;font-family:var(--font-sans);font-size:10px;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;transition:all var(--transition-med);position:relative;}
    .btn-luxury--light{color:var(--color-white);border:1px solid rgba(255,255,255,0.7);}
    .btn-luxury--light:hover{background:var(--color-white);color:var(--color-black);opacity:1;}
    .btn-luxury--dark{color:var(--color-black);border:1px solid var(--color-black);}
    .btn-luxury--dark:hover{background:var(--color-black);color:var(--color-white);opacity:1;}
    .btn-luxury--gold{color:var(--color-gold);border:1px solid var(--color-gold);}
    .btn-luxury--gold:hover{background:var(--color-gold);color:var(--color-white);opacity:1;}
    .page-wrapper{animation:pageFadeIn 0.7s var(--ease-luxury) both;}
    @keyframes pageFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
    .reveal{opacity:0;transform:translateY(28px);transition:opacity 0.9s var(--ease-luxury),transform 0.9s var(--ease-luxury);}
    .reveal.visible{opacity:1;transform:translateY(0);}
    .reveal-delay-1{transition-delay:0.12s;}.reveal-delay-2{transition-delay:0.24s;}.reveal-delay-3{transition-delay:0.36s;}.reveal-delay-4{transition-delay:0.48s;}
    .nav-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:200;}
    .nav-overlay.active{display:block;}
    @media(max-width:768px){.container{padding:0 20px;}}
  </style>
</head>
<body>
  {% section 'announcement-bar' %}
  {% section 'header' %}
  <main class="page-wrapper" role="main" id="main-content">
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}
  <div class="nav-overlay" id="navOverlay"></div>
  <script>
    const reveals=document.querySelectorAll('.reveal');
    const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:0.08,rootMargin:'0px 0px -50px 0px'});
    reveals.forEach(el=>obs.observe(el));
    document.getElementById('navOverlay').addEventListener('click',()=>{document.body.classList.remove('nav-open');document.querySelectorAll('.mobile-nav').forEach(n=>n.classList.remove('active'));document.getElementById('navOverlay').classList.remove('active');});
    const header=document.querySelector('.site-header');
    window.addEventListener('scroll',()=>{header.classList.toggle('scrolled',window.scrollY>80);},{passive:true});
  </script>
</body>
</html>
