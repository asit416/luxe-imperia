{%- if section.settings.show_announcement -%}
<div class="announcement-bar" role="region" aria-label="Announcement">
  <p class="announcement-bar__text">{{ section.settings.text }}</p>
</div>
{%- endif -%}

<style>
  .announcement-bar {
    background: var(--color-black);
    color: var(--color-white);
    text-align: center;
    padding: 10px 20px;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-family: var(--font-sans);
    font-weight: 300;
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {"type":"checkbox","id":"show_announcement","label":"Show announcement bar","default":true},
    {"type":"text","id":"text","label":"Announcement text","default":"Complimentary shipping & returns on all orders — Discover our new collection"}
  ]
}
{% endschema %}
