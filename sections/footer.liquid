<footer class="site-footer" role="contentinfo">

  <!-- Newsletter -->
  {%- if section.settings.show_newsletter -%}
  <div class="footer__newsletter">
    <div class="container">
      <div class="footer__newsletter-inner reveal">
        <div class="footer__newsletter-text">
          <p class="footer__newsletter-label">{{ section.settings.newsletter_label | default: 'The Inner Circle' }}</p>
          <h3 class="footer__newsletter-title">{{ section.settings.newsletter_title | default: 'Be the First to Know' }}</h3>
          <p class="footer__newsletter-subtitle">{{ section.settings.newsletter_subtitle | default: 'Subscribe for exclusive access to new collections, private events, and editorial content.' }}</p>
        </div>
        <div class="footer__newsletter-form">
          {% form 'customer', id: 'footer-newsletter-form', class: 'newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__group">
              <input type="email"
                     name="contact[email]"
                     class="newsletter-form__input"
                     placeholder="Your email address"
                     aria-label="Email address"
                     required
                     autocomplete="email">
              <button type="submit" class="newsletter-form__btn">
                <span>{{ section.settings.newsletter_btn | default: 'Subscribe' }}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </button>
            </div>
            <p class="newsletter-form__consent">{{ section.settings.newsletter_consent | default: 'By subscribing you agree to our Privacy Policy and consent to receive communications from us.' }}</p>
            {% if form.posted_successfully? %}
              <p class="newsletter-form__success">Thank you for subscribing.</p>
            {% endif %}
          {% endform %}
        </div>
      </div>
    </div>
  </div>
  {%- endif -%}

  <!-- Main footer grid -->
  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">

        <!-- Brand column -->
        <div class="footer__col footer__col--brand">
          <a href="/" class="footer__logo" aria-label="{{ shop.name }}">
            {%- if section.settings.footer_logo != blank -%}
              <img src="{{ section.settings.footer_logo | image_url: width: 160 }}"
                   alt="{{ shop.name }}" width="160" loading="lazy">
            {%- else -%}
              <span class="footer__logo-text">{{ shop.name | upcase }}</span>
            {%- endif -%}
          </a>
          {%- if section.settings.brand_text != blank -%}
            <p class="footer__brand-text">{{ section.settings.brand_text }}</p>
          {%- endif -%}
          <!-- Social links -->
          <div class="footer__social">
            {%- if section.settings.social_instagram != blank -%}
              <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="footer__social-link">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_facebook != blank -%}
              <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook" class="footer__social-link">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_twitter != blank -%}
              <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X / Twitter" class="footer__social-link">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_pinterest != blank -%}
              <a href="{{ section.settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest" class="footer__social-link">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                  <path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.852 0 1.265.64 1.265 1.408 0 .858-.548 2.145-.83 3.338-.236.995.499 1.806 1.476 1.806 1.772 0 3.137-1.867 3.137-4.562 0-2.387-1.715-4.056-4.163-4.056-2.837 0-4.503 2.127-4.503 4.327 0 .857.33 1.775.741 2.278a.3.3 0 0 1 .069.285c-.076.312-.243.995-.276 1.134-.044.183-.145.222-.334.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.967-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        </div>

        <!-- Navigation columns from blocks -->
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_column' -%}
          <div class="footer__col" {{ block.shopify_attributes }}>
            <h4 class="footer__col-heading">{{ block.settings.heading }}</h4>
            <ul class="footer__nav-list">
              {%- for i in (1..6) -%}
                {%- assign link_label = 'link_' | append: i | append: '_label' -%}
                {%- assign link_url = 'link_' | append: i | append: '_url' -%}
                {%- if block.settings[link_label] != blank -%}
                  <li><a href="{{ block.settings[link_url] | default: '#' }}">{{ block.settings[link_label] }}</a></li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>
  </div>

  <!-- Footer bottom bar -->
  <div class="footer__bottom">
    <div class="container">
      <div class="footer__bottom-inner">
        <p class="footer__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text | default: 'All rights reserved.' }}
        </p>
        <div class="footer__legal-links">
          {%- if section.settings.policy_privacy != blank -%}
            <a href="{{ section.settings.policy_privacy }}">Privacy Policy</a>
          {%- else -%}
            <a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>
          {%- endif -%}
          {%- if section.settings.policy_terms != blank -%}
            <a href="{{ section.settings.policy_terms }}">Terms of Service</a>
          {%- else -%}
            <a href="{{ shop.terms_of_service.url }}">Terms of Service</a>
          {%- endif -%}
          <a href="{{ shop.refund_policy.url }}">Refund Policy</a>
          <a href="{{ shop.shipping_policy.url }}">Shipping Policy</a>
        </div>
        <div class="footer__payments">
          <!-- Payment icons -->
          <svg viewBox="0 0 38 24" width="38" height="24" aria-label="Visa"><rect width="38" height="24" rx="4" fill="#1a1f71"/><text x="8" y="17" fill="white" font-size="12" font-weight="bold" font-family="Arial">VISA</text></svg>
          <svg viewBox="0 0 38 24" width="38" height="24" aria-label="Mastercard"><rect width="38" height="24" rx="4" fill="#252525"/><circle cx="14" cy="12" r="8" fill="#EB001B"/><circle cx="24" cy="12" r="8" fill="#F79E1B"/></svg>
          <svg viewBox="0 0 38 24" width="38" height="24" aria-label="Amex"><rect width="38" height="24" rx="4" fill="#2E77BC"/><text x="5" y="16" fill="white" font-size="9" font-weight="bold" font-family="Arial">AMEX</text></svg>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ============================================
     FOOTER — LUXURY MINIMAL BLACK
  ============================================ */
  .site-footer {
    background: var(--color-black);
    color: var(--color-white);
    margin-top: auto;
  }

  /* Newsletter */
  .footer__newsletter {
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 80px 0;
  }

  .footer__newsletter-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .footer__newsletter-label {
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 12px;
  }

  .footer__newsletter-title {
    font-family: var(--font-serif);
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 300;
    margin-bottom: 12px;
    line-height: 1.15;
  }

  .footer__newsletter-subtitle {
    font-size: 12px;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(255,255,255,0.55);
  }

  /* Newsletter form */
  .newsletter-form__group {
    display: flex;
    border-bottom: 1px solid rgba(255,255,255,0.3);
    margin-bottom: 16px;
    transition: border-color var(--transition-fast);
  }

  .newsletter-form__group:focus-within {
    border-color: var(--color-gold);
  }

  .newsletter-form__input {
    flex: 1;
    background: none;
    border: none;
    color: var(--color-white);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.06em;
    padding: 14px 0;
    outline: none;
  }

  .newsletter-form__input::placeholder {
    color: rgba(255,255,255,0.35);
    font-style: italic;
  }

  .newsletter-form__btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 0;
    color: var(--color-white);
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: color var(--transition-fast), gap var(--transition-fast);
  }

  .newsletter-form__btn:hover {
    color: var(--color-gold);
    gap: 14px;
  }

  .newsletter-form__consent {
    font-size: 10px;
    line-height: 1.6;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.04em;
  }

  .newsletter-form__success {
    color: var(--color-gold);
    font-size: 12px;
    margin-top: 12px;
    letter-spacing: 0.08em;
  }

  /* Main footer grid */
  .footer__main {
    padding: 72px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 280px repeat(auto-fit, minmax(140px, 1fr));
    gap: 48px;
  }

  .footer__logo-text {
    font-family: var(--font-serif);
    font-size: 20px;
    letter-spacing: 0.22em;
    color: var(--color-white);
  }

  .footer__logo img { opacity: 0.9; filter: brightness(0) invert(1); }

  .footer__brand-text {
    font-size: 11px;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(255,255,255,0.45);
    margin-top: 20px;
    max-width: 240px;
  }

  .footer__social {
    display: flex;
    gap: 18px;
    margin-top: 28px;
  }

  .footer__social-link {
    color: rgba(255,255,255,0.5);
    transition: color var(--transition-fast);
    display: flex;
  }

  .footer__social-link:hover {
    color: var(--color-gold);
    opacity: 1;
  }

  .footer__col-heading {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 24px;
  }

  .footer__nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__nav-list a {
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.65);
    transition: color var(--transition-fast);
  }

  .footer__nav-list a:hover {
    color: var(--color-white);
    opacity: 1;
  }

  /* Bottom bar */
  .footer__bottom {
    padding: 24px 0;
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .footer__copyright {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.3);
  }

  .footer__legal-links {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .footer__legal-links a {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.35);
    transition: color var(--transition-fast);
  }

  .footer__legal-links a:hover {
    color: var(--color-white);
    opacity: 1;
  }

  .footer__payments {
    display: flex;
    gap: 8px;
    align-items: center;
    opacity: 0.5;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer__newsletter-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer__newsletter { padding: 56px 0; }
    .footer__main { padding: 48px 0; }
    .footer__grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer__bottom-inner { flex-direction: column; text-align: center; }
    .footer__legal-links { justify-content: center; }
    .footer__payments { justify-content: center; }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {"type":"image_picker","id":"footer_logo","label":"Footer logo"},
    {"type":"textarea","id":"brand_text","label":"Brand description"},
    {"type":"text","id":"copyright_text","label":"Copyright text"},
    {"type":"checkbox","id":"show_newsletter","label":"Show newsletter section","default":true},
    {"type":"text","id":"newsletter_label","label":"Newsletter label","default":"The Inner Circle"},
    {"type":"text","id":"newsletter_title","label":"Newsletter title","default":"Be the First to Know"},
    {"type":"text","id":"newsletter_subtitle","label":"Newsletter subtitle"},
    {"type":"text","id":"newsletter_btn","label":"Newsletter button text","default":"Subscribe"},
    {"type":"text","id":"newsletter_consent","label":"Consent text"},
    {"type":"url","id":"policy_privacy","label":"Privacy policy URL"},
    {"type":"url","id":"policy_terms","label":"Terms of service URL"},
    {"type":"text","id":"social_instagram","label":"Instagram URL"},
    {"type":"text","id":"social_facebook","label":"Facebook URL"},
    {"type":"text","id":"social_twitter","label":"X / Twitter URL"},
    {"type":"text","id":"social_pinterest","label":"Pinterest URL"}
  ],
  "blocks": [
    {
      "type": "nav_column",
      "name": "Navigation Column",
      "settings": [
        {"type":"text","id":"heading","label":"Column heading"},
        {"type":"text","id":"link_1_label","label":"Link 1 label"},{"type":"url","id":"link_1_url","label":"Link 1 URL"},
        {"type":"text","id":"link_2_label","label":"Link 2 label"},{"type":"url","id":"link_2_url","label":"Link 2 URL"},
        {"type":"text","id":"link_3_label","label":"Link 3 label"},{"type":"url","id":"link_3_url","label":"Link 3 URL"},
        {"type":"text","id":"link_4_label","label":"Link 4 label"},{"type":"url","id":"link_4_url","label":"Link 4 URL"},
        {"type":"text","id":"link_5_label","label":"Link 5 label"},{"type":"url","id":"link_5_url","label":"Link 5 URL"},
        {"type":"text","id":"link_6_label","label":"Link 6 label"},{"type":"url","id":"link_6_url","label":"Link 6 URL"}
      ]
    }
  ],
  "presets": []
}
{% endschema %}
