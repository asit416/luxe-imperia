<header class="site-header" role="banner" id="siteHeader">
  <div class="header__inner">

    <!-- Mobile menu toggle -->
    <button class="header__menu-toggle" id="menuToggle" aria-label="Open menu" aria-expanded="false">
      <span class="menu-icon">
        <span></span><span></span><span></span>
      </span>
    </button>

    <!-- Left nav -->
    <nav class="header__nav header__nav--left" role="navigation" aria-label="Main navigation left">
      <ul class="nav-list">
        <li class="nav-item nav-item--has-dropdown">
          <a href="/collections/women" class="nav-link">Women</a>
          <div class="mega-menu">
            <div class="mega-menu__inner container">
              <div class="mega-menu__col">
                <p class="mega-menu__heading">New Arrivals</p>
                <ul>
                  <li><a href="/collections/women-new">New This Week</a></li>
                  <li><a href="/collections/women-featured">Featured</a></li>
                  <li><a href="/collections/women-bestsellers">Bestsellers</a></li>
                </ul>
              </div>
              <div class="mega-menu__col">
                <p class="mega-menu__heading">Clothing</p>
                <ul>
                  <li><a href="/collections/women-dresses">Dresses</a></li>
                  <li><a href="/collections/women-jackets">Jackets & Coats</a></li>
                  <li><a href="/collections/women-tops">Tops & Shirts</a></li>
                  <li><a href="/collections/women-trousers">Trousers</a></li>
                  <li><a href="/collections/women-skirts">Skirts</a></li>
                </ul>
              </div>
              <div class="mega-menu__col">
                <p class="mega-menu__heading">Bags & Leather</p>
                <ul>
                  <li><a href="/collections/women-handbags">Handbags</a></li>
                  <li><a href="/collections/women-shoulder">Shoulder Bags</a></li>
                  <li><a href="/collections/women-totes">Totes</a></li>
                  <li><a href="/collections/women-wallets">Wallets</a></li>
                </ul>
              </div>
              <div class="mega-menu__col">
                <p class="mega-menu__heading">Shoes</p>
                <ul>
                  <li><a href="/collections/women-heels">Heels</a></li>
                  <li><a href="/collections/women-flats">Flats</a></li>
                  <li><a href="/collections/women-boots">Boots</a></li>
                  <li><a href="/collections/women-sneakers">Sneakers</a></li>
                </ul>
              </div>
              <div class="mega-menu__col mega-menu__col--image">
                {%- if section.settings.women_menu_image != blank -%}
                  <a href="/collections/women">
                    <img src="{{ section.settings.women_menu_image | image_url: width: 300 }}" alt="Women's Collection" loading="lazy">
                    <p class="mega-menu__image-label">Explore Women</p>
                  </a>
                {%- else -%}
                  <a href="/collections/women" class="mega-menu__image-placeholder">
                    <div class="placeholder-block"></div>
                    <p class="mega-menu__image-label">Explore Women</p>
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item nav-item--has-dropdown">
          <a href="/collections/men" class="nav-link">Men</a>
          <div class="mega-menu">
            <div class="mega-menu__inner container">
              <div class="mega-menu__col">
                <p class="mega-menu__heading">New Arrivals</p>
                <ul>
                  <li><a href="/collections/men-new">New This Week</a></li>
                  <li><a href="/collections/men-featured">Featured</a></li>
                  <li><a href="/collections/men-bestsellers">Bestsellers</a></li>
                </ul>
              </div>
              <div class="mega-menu__col">
                <p class="mega-menu__heading">Clothing</p>
                <ul>
                  <li><a href="/collections/men-suits">Suits</a></li>
                  <li><a href="/collections/men-jackets">Jackets & Coats</a></li>
                  <li><a href="/collections/men-shirts">Shirts</a></li>
                  <li><a href="/collections/men-trousers">Trousers</a></li>
                  <li><a href="/collections/men-knitwear">Knitwear</a></li>
                </ul>
              </div>
              <div class="mega-menu__col">
                <p class="mega-menu__heading">Bags & Leather</p>
                <ul>
                  <li><a href="/collections/men-bags">Bags</a></li>
                  <li><a href="/collections/men-briefcases">Briefcases</a></li>
                  <li><a href="/collections/men-belts">Belts</a></li>
                  <li><a href="/collections/men-wallets">Wallets</a></li>
                </ul>
              </div>
              <div class="mega-menu__col">
                <p class="mega-menu__heading">Shoes</p>
                <ul>
                  <li><a href="/collections/men-loafers">Loafers</a></li>
                  <li><a href="/collections/men-oxfords">Oxfords</a></li>
                  <li><a href="/collections/men-boots">Boots</a></li>
                  <li><a href="/collections/men-sneakers">Sneakers</a></li>
                </ul>
              </div>
              <div class="mega-menu__col mega-menu__col--image">
                {%- if section.settings.men_menu_image != blank -%}
                  <a href="/collections/men">
                    <img src="{{ section.settings.men_menu_image | image_url: width: 300 }}" alt="Men's Collection" loading="lazy">
                    <p class="mega-menu__image-label">Explore Men</p>
                  </a>
                {%- else -%}
                  <a href="/collections/men" class="mega-menu__image-placeholder">
                    <div class="placeholder-block"></div>
                    <p class="mega-menu__image-label">Explore Men</p>
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item nav-item--has-dropdown">
          <a href="/collections/all" class="nav-link">Collections</a>
          <div class="mega-menu mega-menu--simple">
            <div class="mega-menu__inner container">
              <div class="mega-menu__col">
                <ul>
                  <li><a href="/collections/ss25">Spring / Summer 2025</a></li>
                  <li><a href="/collections/cruise">Cruise Collection</a></li>
                  <li><a href="/collections/pre-fall">Pre-Fall</a></li>
                  <li><a href="/collections/archive">Archive</a></li>
                </ul>
              </div>
            </div>
          </div>
        </li>
      </ul>
    </nav>

    <!-- Logo (centered) -->
    <div class="header__logo">
      <a href="/" class="header__logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 180 }}"
               alt="{{ shop.name }}"
               width="180"
               class="header__logo-img">
        {%- else -%}
          <span class="header__logo-text">{{ shop.name | upcase }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Right nav -->
    <nav class="header__nav header__nav--right" role="navigation" aria-label="Main navigation right">
      <ul class="nav-list">
        <li class="nav-item nav-item--has-dropdown">
          <a href="/collections/accessories" class="nav-link">Accessories</a>
          <div class="mega-menu mega-menu--simple">
            <div class="mega-menu__inner container">
              <div class="mega-menu__col">
                <p class="mega-menu__heading">Categories</p>
                <ul>
                  <li><a href="/collections/jewelry">Jewellery</a></li>
                  <li><a href="/collections/watches">Watches</a></li>
                  <li><a href="/collections/sunglasses">Eyewear</a></li>
                  <li><a href="/collections/scarves">Scarves & Wraps</a></li>
                  <li><a href="/collections/hats">Hats & Caps</a></li>
                  <li><a href="/collections/fragrance">Fragrance</a></li>
                </ul>
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item">
          <a href="/pages/world" class="nav-link">World</a>
        </li>
      </ul>
    </nav>

    <!-- Icon actions -->
    <div class="header__actions">
      <button class="header__action-btn" id="searchToggle" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <a href="/account" class="header__action-btn" aria-label="Account">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </a>
      <a href="/wishlist" class="header__action-btn" aria-label="Wishlist">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </a>
      <a href="/cart" class="header__action-btn header__cart-btn" aria-label="Cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>

  <!-- Search overlay -->
  <div class="search-overlay" id="searchOverlay">
    <div class="search-overlay__inner">
      <form action="/search" method="get" class="search-form" role="search">
        <input type="hidden" name="type" value="product">
        <input class="search-form__input" type="search" name="q"
               placeholder="Search for products, collections..." 
               aria-label="Search" autocomplete="off">
        <button type="submit" class="search-form__submit" aria-label="Submit search">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </form>
      <button class="search-overlay__close" id="searchClose" aria-label="Close search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Navigation -->
<nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation" aria-hidden="true">
  <div class="mobile-nav__header">
    <button class="mobile-nav__close" id="mobileNavClose" aria-label="Close menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <ul class="mobile-nav__list">
    <li><a href="/collections/women" class="mobile-nav__link">Women</a></li>
    <li><a href="/collections/men" class="mobile-nav__link">Men</a></li>
    <li><a href="/collections/all" class="mobile-nav__link">Collections</a></li>
    <li><a href="/collections/accessories" class="mobile-nav__link">Accessories</a></li>
    <li><a href="/pages/world" class="mobile-nav__link">World</a></li>
  </ul>
  <div class="mobile-nav__footer">
    <a href="/account">My Account</a>
    <a href="/wishlist">Wishlist</a>
    <a href="/pages/contact">Contact</a>
  </div>
</nav>

<style>
  /* ============================================
     HEADER — LUXURY THIN NAV
  ============================================ */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
    transition: background var(--transition-med), box-shadow var(--transition-med);
  }

  /* Transparent on hero, solid when scrolled */
  .site-header.scrolled {
    background: var(--color-white);
    box-shadow: 0 1px 0 rgba(0,0,0,0.08);
  }

  .site-header.header--dark-mode {
    color: var(--color-white);
  }

  .site-header.header--dark-mode.scrolled {
    color: var(--color-black);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    padding: 0 24px;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Navigation lists */
  .nav-list {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 10.5px;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 8px 0;
    position: relative;
    transition: opacity var(--transition-fast);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: currentColor;
    transition: width var(--transition-med);
  }

  .nav-item:hover .nav-link::after { width: 100%; }
  .nav-link:hover { opacity: 1; }

  /* Logo */
  .header__logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .header__logo-text {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .header__logo-img {
    max-height: 32px;
    width: auto;
  }

  /* Action icons */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .header__action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: opacity var(--transition-fast);
    color: inherit;
  }

  .header__action-btn:hover { opacity: 0.6; }

  .cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background: var(--color-black);
    color: var(--color-white);
    font-size: 8px;
    font-weight: 500;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0;
  }

  /* Mega Menu */
  .mega-menu {
    position: absolute;
    top: var(--header-height);
    left: 0;
    right: 0;
    background: var(--color-white);
    border-top: 1px solid var(--color-warm-grey);
    border-bottom: 1px solid var(--color-warm-grey);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: opacity var(--transition-med), transform var(--transition-med), visibility var(--transition-med);
    z-index: 200;
  }

  .nav-item:hover .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mega-menu__inner {
    display: flex;
    gap: 48px;
    padding: 48px 48px;
    align-items: flex-start;
  }

  .mega-menu__col {
    flex: 1;
    min-width: 0;
  }

  .mega-menu__col--image {
    flex: 0 0 200px;
  }

  .mega-menu__col--image img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
  }

  .mega-menu__col--image .placeholder-block {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--color-cream);
  }

  .mega-menu__image-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 12px;
    text-align: center;
  }

  .mega-menu__heading {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-mid-grey);
    margin-bottom: 16px;
  }

  .mega-menu__col ul { list-style: none; }

  .mega-menu__col li {
    margin-bottom: 12px;
  }

  .mega-menu__col a {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .mega-menu__col a:hover {
    color: var(--color-gold);
    opacity: 1;
  }

  /* Search Overlay */
  .search-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: var(--color-white);
    z-index: 400;
    padding: 0;
    transform: translateY(-100%);
    transition: transform var(--transition-med);
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

  .search-overlay.active {
    transform: translateY(0);
  }

  .search-overlay__inner {
    display: flex;
    align-items: center;
    height: var(--header-height);
    padding: 0 48px;
    max-width: var(--max-width);
    margin: 0 auto;
    gap: 20px;
  }

  .search-form {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid var(--color-black);
    padding-bottom: 8px;
  }

  .search-form__input {
    flex: 1;
    border: none;
    background: none;
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--color-text);
    outline: none;
  }

  .search-form__input::placeholder {
    color: var(--color-mid-grey);
    font-style: italic;
  }

  .search-form__submit, .search-overlay__close {
    display: flex;
    align-items: center;
    color: var(--color-text);
    transition: opacity var(--transition-fast);
  }

  .search-form__submit:hover, .search-overlay__close:hover { opacity: 0.5; }

  /* Mobile nav */
  .mobile-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 340px;
    height: 100vh;
    background: var(--color-white);
    z-index: 500;
    transform: translateX(-100%);
    transition: transform var(--transition-slow);
    padding: 0;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .mobile-nav.active {
    transform: translateX(0);
  }

  .mobile-nav__header {
    display: flex;
    justify-content: flex-end;
    padding: 20px 24px;
    border-bottom: 1px solid var(--color-warm-grey);
  }

  .mobile-nav__list {
    list-style: none;
    padding: 32px 32px;
    flex: 1;
  }

  .mobile-nav__list li {
    border-bottom: 1px solid var(--color-warm-grey);
  }

  .mobile-nav__link {
    display: block;
    padding: 20px 0;
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .mobile-nav__link:hover {
    color: var(--color-gold);
    opacity: 1;
  }

  .mobile-nav__footer {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    border-top: 1px solid var(--color-warm-grey);
  }

  .mobile-nav__footer a {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Menu toggle button */
  .header__menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }

  .menu-icon span {
    display: block;
    width: 22px;
    height: 1px;
    background: currentColor;
    transition: all var(--transition-fast);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .header__nav { display: none; }
    .header__menu-toggle { display: flex; }
    .header__logo { position: static; transform: none; }
    .header__inner { justify-content: space-between; }
  }

  @media (max-width: 480px) {
    .header__inner { padding: 0 16px; }
    .header__actions { gap: 14px; }
    .mobile-nav { width: 100%; }
  }
</style>

<script>
  // Search toggle
  const searchToggle = document.getElementById('searchToggle');
  const searchOverlay = document.getElementById('searchOverlay');
  const searchClose = document.getElementById('searchClose');

  searchToggle.addEventListener('click', () => {
    searchOverlay.classList.add('active');
    searchOverlay.querySelector('input').focus();
  });

  searchClose.addEventListener('click', () => {
    searchOverlay.classList.remove('active');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchOverlay.classList.remove('active');
      mobileNav.classList.remove('active');
      document.body.classList.remove('nav-open');
      document.getElementById('navOverlay').classList.remove('active');
    }
  });

  // Mobile nav
  const menuToggle = document.getElementById('menuToggle');
  const mobileNav = document.getElementById('mobileNav');
  const mobileNavClose = document.getElementById('mobileNavClose');

  menuToggle.addEventListener('click', () => {
    const isOpen = mobileNav.classList.toggle('active');
    document.body.classList.toggle('nav-open', isOpen);
    document.getElementById('navOverlay').classList.toggle('active', isOpen);
    menuToggle.setAttribute('aria-expanded', isOpen);
    mobileNav.setAttribute('aria-hidden', !isOpen);
  });

  mobileNavClose.addEventListener('click', () => {
    mobileNav.classList.remove('active');
    document.body.classList.remove('nav-open');
    document.getElementById('navOverlay').classList.remove('active');
    menuToggle.setAttribute('aria-expanded', false);
  });

  // Hero transparency: make header transparent over hero
  const hero = document.querySelector('.hero-section');
  if (hero) {
    const header = document.getElementById('siteHeader');
    header.classList.add('header--dark-mode');
    header.style.color = 'white';
    window.addEventListener('scroll', () => {
      if (window.scrollY > hero.offsetHeight * 0.5) {
        header.style.color = '';
      } else {
        header.style.color = header.classList.contains('scrolled') ? '' : 'white';
      }
    }, { passive: true });
  }
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {"type":"image_picker","id":"logo","label":"Logo image"},
    {"type":"image_picker","id":"women_menu_image","label":"Women mega menu image"},
    {"type":"image_picker","id":"men_menu_image","label":"Men mega menu image"}
  ]
}
{% endschema %}
