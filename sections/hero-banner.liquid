<section class="hero-section" style="--hero-height:{{ section.settings.height }};">
  <div class="hero__media">
    {%- if section.settings.video_url != blank -%}
      <video class="hero__video"
             autoplay muted loop playsinline
             poster="{{ section.settings.image | image_url: width: 1920 }}">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      <img class="hero__image"
           src="{{ section.settings.image | image_url: width: 2400 }}"
           srcset="{{ section.settings.image | image_url: width: 768 }} 768w,
                   {{ section.settings.image | image_url: width: 1200 }} 1200w,
                   {{ section.settings.image | image_url: width: 1920 }} 1920w,
                   {{ section.settings.image | image_url: width: 2400 }} 2400w"
           sizes="100vw"
           alt="{{ section.settings.title | escape }}"
           loading="eager"
           fetchpriority="high">
    {%- else -%}
      <div class="hero__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder-svg' }}
      </div>
    {%- endif -%}
    <div class="hero__overlay" style="--overlay-opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  </div>

  <div class="hero__content hero__content--{{ section.settings.text_position }}">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h1 class="hero__title">{{ section.settings.title }}</h1>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url }}"
         class="btn-luxury btn-luxury--light hero__cta">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
    {%- if section.settings.cta_secondary_label != blank -%}
      <a href="{{ section.settings.cta_secondary_url }}"
         class="hero__cta-secondary">
        {{ section.settings.cta_secondary_label }}
      </a>
    {%- endif -%}
  </div>

  {%- if section.settings.show_scroll_indicator -%}
    <div class="hero__scroll-indicator" aria-hidden="true">
      <div class="scroll-line"></div>
    </div>
  {%- endif -%}
</section>

<style>
  /* ============================================
     HERO SECTION — CINEMATIC FULL-SCREEN
  ============================================ */
  .hero-section {
    position: relative;
    width: 100%;
    height: var(--hero-height, 100vh);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Media layer */
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image,
  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.03);
    animation: heroKenBurns 12s var(--ease-luxury) forwards;
  }

  .hero__video { transform: none; animation: none; }

  @keyframes heroKenBurns {
    from { transform: scale(1.06); }
    to   { transform: scale(1.0); }
  }

  .hero__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, #1a1a1a 0%, #2d2a25 50%, #1a1a1a 100%);
  }

  .hero__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--overlay-opacity, 0.25));
  }

  /* Content layer */
  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--color-white);
    padding: 20px;
    max-width: 800px;
    animation: heroContentReveal 1.2s var(--ease-luxury) 0.3s both;
  }

  .hero__content--left {
    position: absolute;
    left: 8%;
    bottom: 12%;
    text-align: left;
  }

  .hero__content--right {
    position: absolute;
    right: 8%;
    bottom: 12%;
    text-align: right;
  }

  .hero__content--bottom-center {
    position: absolute;
    bottom: 10%;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
  }

  @keyframes heroContentReveal {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 16px;
    opacity: 0.8;
  }

  .hero__title {
    font-family: var(--font-serif);
    font-size: clamp(42px, 6vw, 90px);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: 0.04em;
    margin-bottom: 20px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.2);
  }

  .hero__subtitle {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.15em;
    margin-bottom: 36px;
    opacity: 0.85;
  }

  .hero__cta {
    display: inline-block;
    animation: heroContentReveal 1.2s var(--ease-luxury) 0.7s both;
  }

  .hero__cta-secondary {
    display: block;
    margin-top: 18px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-white);
    text-decoration: underline;
    text-underline-offset: 4px;
    opacity: 0.75;
    transition: opacity var(--transition-fast);
  }

  .hero__cta-secondary:hover { opacity: 1; }

  /* Scroll indicator */
  .hero__scroll-indicator {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
  }

  .scroll-line {
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.7));
    margin: 0 auto;
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-section { height: 92vh; min-height: 560px; }
    .hero__content--left,
    .hero__content--right,
    .hero__content--bottom-center {
      position: relative;
      left: auto; right: auto; bottom: auto;
      transform: none;
      text-align: center;
    }
    .hero__title { font-size: clamp(32px, 9vw, 52px); }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section-wrapper",
  "settings": [
    {"type":"image_picker","id":"image","label":"Hero image"},
    {"type":"text","id":"video_url","label":"Video URL (MP4, optional)"},
    {"type":"select","id":"height","label":"Section height","options":[
      {"value":"100vh","label":"Full screen"},
      {"value":"90vh","label":"90% screen"},
      {"value":"80vh","label":"80% screen"},
      {"value":"70vh","label":"70% screen"}
    ],"default":"100vh"},
    {"type":"range","id":"overlay_opacity","label":"Image overlay opacity","min":0,"max":70,"step":5,"default":25},
    {"type":"select","id":"text_position","label":"Text position","options":[
      {"value":"center","label":"Center"},
      {"value":"left","label":"Bottom left"},
      {"value":"right","label":"Bottom right"},
      {"value":"bottom-center","label":"Bottom center"}
    ],"default":"center"},
    {"type":"text","id":"eyebrow","label":"Eyebrow text"},
    {"type":"text","id":"title","label":"Headline","default":"The New Collection"},
    {"type":"text","id":"subtitle","label":"Subtitle","default":"Spring — Summer 2025"},
    {"type":"text","id":"cta_label","label":"Primary button label","default":"Discover Now"},
    {"type":"url","id":"cta_url","label":"Primary button link"},
    {"type":"text","id":"cta_secondary_label","label":"Secondary link label"},
    {"type":"url","id":"cta_secondary_url","label":"Secondary link URL"},
    {"type":"checkbox","id":"show_scroll_indicator","label":"Show scroll indicator","default":true}
  ],
  "presets": [{"name":"Hero Banner"}]
}
{% endschema %}
