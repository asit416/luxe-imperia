{% comment %}
  SECTION: hero.liquid
  LOCATION: sections/hero.liquid
  USAGE: Add as first section on homepage via theme editor → Sections → Add section → Hero
  Replace image/video with your campaign creative. For video, paste an mp4 URL.
{% endcomment %}

<style>
.hero {
  position: relative;
  width: 100%;
  height: 100svh;
  min-height: 600px;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  padding-bottom: clamp(60px, 8vw, 110px);
  padding-left: clamp(24px, 7vw, 100px);
  padding-right: clamp(24px, 7vw, 100px);
}

/* Media */
.hero__media {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero__img,
.hero__video {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: {{ section.settings.focal_point | default: 'center center' }};
  transform: scale(1.04);
  animation: heroZoom 10s var(--ease-luxury) forwards;
}
@keyframes heroZoom {
  to { transform: scale(1); }
}

/* Gradient overlay */
.hero__overlay {
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(0,0,0,0.02) 0%,
    rgba(0,0,0,0.08) 40%,
    rgba(0,0,0,0.52) 80%,
    rgba(0,0,0,0.72) 100%
  );
}

/* Content */
.hero__content {
  position: relative;
  z-index: 2;
  max-width: 700px;
  color: var(--c-white);
}
.hero__eyebrow {
  font-family: var(--font-ui);
  font-size: 0.62rem;
  font-weight: 300;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  margin-bottom: 20px;
  opacity: 0;
  transform: translateY(20px);
  animation: heroFadeUp 1s 0.4s var(--ease-reveal) forwards;
}
.hero__title {
  font-family: var(--font-display);
  font-size: clamp(3rem, 7vw, 7.5rem);
  font-weight: 300;
  line-height: 1.0;
  letter-spacing: -0.01em;
  margin-bottom: 28px;
  opacity: 0;
  transform: translateY(30px);
  animation: heroFadeUp 1.1s 0.6s var(--ease-reveal) forwards;
}
.hero__subtitle {
  font-family: var(--font-body);
  font-size: clamp(0.95rem, 1.4vw, 1.15rem);
  font-weight: 400;
  color: rgba(255,255,255,0.8);
  max-width: 440px;
  line-height: 1.7;
  margin-bottom: 44px;
  opacity: 0;
  transform: translateY(20px);
  animation: heroFadeUp 1s 0.85s var(--ease-reveal) forwards;
}
.hero__cta-wrap {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  opacity: 0;
  transform: translateY(20px);
  animation: heroFadeUp 1s 1.05s var(--ease-reveal) forwards;
}

@keyframes heroFadeUp {
  to { opacity: 1; transform: translateY(0); }
}

/* Scroll indicator */
.hero__scroll {
  position: absolute;
  bottom: 40px; right: clamp(24px, 5vw, 60px);
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  color: rgba(255,255,255,0.55);
  opacity: 0;
  animation: heroFadeUp 1s 1.4s var(--ease-reveal) forwards;
}
.hero__scroll-text {
  font-family: var(--font-ui);
  font-size: 0.55rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  writing-mode: vertical-rl;
}
.hero__scroll-line {
  width: 1px; height: 50px;
  background: rgba(255,255,255,0.3);
  position: relative;
  overflow: hidden;
}
.hero__scroll-line::after {
  content: '';
  position: absolute;
  top: -100%; left: 0;
  width: 100%; height: 100%;
  background: rgba(255,255,255,0.7);
  animation: scrollLine 1.8s 1.6s ease-in-out infinite;
}
@keyframes scrollLine {
  0%  { top: -100%; }
  100%{ top: 100%; }
}

/* Volume toggle for video */
.hero__mute {
  position: absolute;
  bottom: 40px; left: clamp(24px, 5vw, 60px);
  z-index: 3;
  display: flex; align-items: center; gap: 8px;
  color: rgba(255,255,255,0.55);
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: 0.58rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  transition: color 0.3s;
  opacity: 0;
  animation: heroFadeUp 1s 1.4s var(--ease-reveal) forwards;
}
.hero__mute:hover { color: var(--c-white); }
.hero__mute svg { width: 18px; height: 18px; }

/* Mobile */
@media (max-width: 640px) {
  .hero { padding-left: 24px; padding-right: 24px; align-items: center; padding-bottom: 0; }
  .hero__content { text-align: center; max-width: 100%; }
  .hero__subtitle { display: none; }
  .hero__cta-wrap { justify-content: center; }
  .hero__scroll { display: none; }
}
</style>

<section class="hero" id="hero">

  <div class="hero__media">
    {% if section.settings.video_url != blank %}
      <video
        class="hero__video"
        src="{{ section.settings.video_url }}"
        autoplay muted loop playsinline
        poster="{{ section.settings.image | img_url: '2000x' }}"
        id="hero-video">
      </video>
    {% elsif section.settings.image != blank %}
      <img
        class="hero__img"
        src="{{ section.settings.image | img_url: '2000x' }}"
        srcset="{{ section.settings.image | img_url: '800x' }} 800w,
                {{ section.settings.image | img_url: '1400x' }} 1400w,
                {{ section.settings.image | img_url: '2000x' }} 2000w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        loading="eager"
        fetchpriority="high">
    {% else %}
      {%- comment -%} Fallback gradient for editor preview {%- endcomment -%}
      <div style="position:absolute;inset:0;background:linear-gradient(135deg,#1a1a18 0%,#3d3830 50%,#1a1a18 100%);"></div>
    {% endif %}
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    {% if section.settings.eyebrow != blank %}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    <h1 class="hero__title">{{ section.settings.heading | default: 'The New Collection' }}</h1>

    {% if section.settings.subheading != blank %}
      <p class="hero__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="hero__cta-wrap">
      {% if section.settings.cta_primary_label != blank %}
        <a href="{{ section.settings.cta_primary_url | default: '/collections/all' }}"
           class="btn-luxury-outline">
          <span>{{ section.settings.cta_primary_label }}</span>
        </a>
      {% endif %}
      {% if section.settings.cta_secondary_label != blank %}
        <a href="{{ section.settings.cta_secondary_url }}"
           class="btn-luxury-outline" style="border-color:rgba(255,255,255,0.3);color:rgba(255,255,255,0.7);">
          <span>{{ section.settings.cta_secondary_label }}</span>
        </a>
      {% endif %}
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-text">Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>

  {% if section.settings.video_url != blank %}
    <button class="hero__mute" id="hero-mute-btn" aria-label="Toggle sound">
      <svg id="icon-muted" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
      <svg id="icon-unmuted" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display:none;">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
      <span id="mute-label">Sound</span>
    </button>
    <script>
      (function(){
        const btn   = document.getElementById('hero-mute-btn');
        const video = document.getElementById('hero-video');
        const iM    = document.getElementById('icon-muted');
        const iU    = document.getElementById('icon-unmuted');
        const lbl   = document.getElementById('mute-label');
        if (!btn || !video) return;
        btn.addEventListener('click', () => {
          video.muted = !video.muted;
          iM.style.display = video.muted ? '' : 'none';
          iU.style.display = video.muted ? 'none' : '';
          lbl.textContent  = video.muted ? 'Sound' : 'Mute';
        });
      })();
    </script>
  {% endif %}

</section>

{% schema %}
{
  "name": "Hero — Cinematic",
  "settings": [
    { "type": "header",   "content": "Media" },
    { "type": "image_picker", "id": "image",       "label": "Campaign Image" },
    { "type": "text",     "id": "video_url",        "label": "Video URL (.mp4) — overrides image" },
    { "type": "select",   "id": "focal_point",      "label": "Image focal point",
      "options": [
        {"value":"center center","label":"Center"},
        {"value":"top center",   "label":"Top"},
        {"value":"bottom center","label":"Bottom"},
        {"value":"center left",  "label":"Left"},
        {"value":"center right", "label":"Right"}
      ], "default": "center center" },
    { "type": "header",   "content": "Content" },
    { "type": "text",     "id": "eyebrow",          "label": "Eyebrow label",       "default": "Pre-Fall Collection" },
    { "type": "text",     "id": "heading",           "label": "Heading",             "default": "Redefined Elegance" },
    { "type": "textarea", "id": "subheading",        "label": "Subheading",
      "default": "A new chapter in contemporary luxury, where craft meets modernity." },
    { "type": "header",   "content": "Primary CTA" },
    { "type": "text",     "id": "cta_primary_label", "label": "Button label",        "default": "Discover the Collection" },
    { "type": "url",      "id": "cta_primary_url",   "label": "Button URL" },
    { "type": "header",   "content": "Secondary CTA (optional)" },
    { "type": "text",     "id": "cta_secondary_label","label": "Button label" },
    { "type": "url",      "id": "cta_secondary_url",  "label": "Button URL" }
  ],
  "presets": [{ "name": "Hero — Cinematic" }]
}
{% endschema %}
