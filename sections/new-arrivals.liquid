{% comment %}
  SECTION: new-arrivals.liquid
  LOCATION: sections/new-arrivals.liquid
  USAGE: Add on homepage to display latest products.
  Link to any collection in your Shopify store.
{% endcomment %}

<style>
.arrivals-section {
  padding: var(--section-pad-v) var(--section-pad-h);
  background: var(--c-white);
}
.arrivals-top {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: clamp(40px, 5vw, 64px);
  gap: 20px;
  flex-wrap: wrap;
}
.arrivals-top-left {}
.arrivals-eyebrow {
  font-family: var(--font-ui);
  font-size: 0.6rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--c-warm-gray);
  margin-bottom: 12px;
}
.arrivals-heading {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.5vw, 3.8rem);
  font-weight: 300;
  line-height: 1.1;
  color: var(--c-black);
}

/* Product grid */
.product-grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns | default: 4 }}, 1fr);
  gap: clamp(12px, 2.5vw, 32px) clamp(12px, 2vw, 24px);
}
@media (max-width: 1100px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 740px)  { .product-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 400px)  { .product-grid { grid-template-columns: 1fr; } }

/* Product card */
.product-card {
  display: flex;
  flex-direction: column;
  cursor: pointer;
}
.product-card__media {
  position: relative;
  overflow: hidden;
  aspect-ratio: 2/3;
  background: var(--c-beige);
  margin-bottom: clamp(12px, 2vw, 20px);
}
.product-card__img {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  transition: opacity 0.6s var(--ease-luxury), transform 0.8s var(--ease-luxury);
}
.product-card__img-alt {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.6s var(--ease-luxury);
}
.product-card:hover .product-card__img     { opacity: 0; transform: scale(1.03); }
.product-card:hover .product-card__img-alt { opacity: 1; }

/* Quick actions */
.product-card__actions {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transform: translateY(100%);
  transition: transform 0.45s var(--ease-luxury);
  z-index: 2;
}
.product-card:hover .product-card__actions { transform: translateY(0); }

.product-card__add-btn {
  width: 100%;
  padding: 12px;
  background: var(--c-black);
  color: var(--c-white);
  font-family: var(--font-ui);
  font-size: 0.58rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-align: center;
  border: 1px solid var(--c-black);
  cursor: pointer;
  transition: background 0.3s, color 0.3s;
  display: block;
}
.product-card__add-btn:hover { background: transparent; color: var(--c-black); }

.product-card__wish-btn {
  position: absolute;
  top: 16px; right: 16px;
  width: 36px; height: 36px;
  background: rgba(255,255,255,0.9);
  border: none;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  opacity: 0;
  transform: scale(0.8);
  transition: opacity 0.3s, transform 0.3s, background 0.3s;
  z-index: 3;
}
.product-card:hover .product-card__wish-btn { opacity: 1; transform: scale(1); }
.product-card__wish-btn:hover { background: var(--c-white); }
.product-card__wish-btn svg { width: 16px; height: 16px; stroke: var(--c-black); fill: none; }
.product-card__wish-btn.active svg { fill: var(--c-black); }

/* New badge */
.product-card__badge {
  position: absolute;
  top: 16px; left: 16px;
  background: var(--c-black);
  color: var(--c-white);
  font-family: var(--font-ui);
  font-size: 0.5rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 5px 10px;
  z-index: 2;
}

/* Info */
.product-card__info {}
.product-card__category {
  font-family: var(--font-ui);
  font-size: 0.55rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--c-warm-gray);
  margin-bottom: 6px;
}
.product-card__name {
  font-family: var(--font-display);
  font-size: clamp(1rem, 1.5vw, 1.35rem);
  font-weight: 400;
  line-height: 1.3;
  color: var(--c-black);
  margin-bottom: 8px;
  letter-spacing: 0.01em;
}
.product-card__price {
  font-family: var(--font-ui);
  font-size: 0.72rem;
  font-weight: 300;
  letter-spacing: 0.08em;
  color: var(--c-mid-gray);
}

/* Colour swatches */
.product-card__swatches {
  display: flex;
  gap: 6px;
  margin-top: 10px;
}
.swatch {
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 1px solid transparent;
  cursor: pointer;
  transition: border-color 0.2s;
}
.swatch:hover, .swatch.active { border-color: var(--c-black); }

/* Bottom link */
.arrivals-footer {
  text-align: center;
  margin-top: clamp(48px, 5vw, 80px);
}
</style>

<section class="arrivals-section" id="new-arrivals">
  <div class="arrivals-top">
    <div class="arrivals-top-left">
      {% if section.settings.eyebrow != blank %}
        <p class="arrivals-eyebrow fade-up" data-scroll-reveal>{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="arrivals-heading fade-up delay-1" data-scroll-reveal>
        {{ section.settings.heading | default: 'New Arrivals' }}
      </h2>
    </div>
    {% if section.settings.view_all_url != blank %}
      <a href="{{ section.settings.view_all_url }}" class="btn-ghost fade-up delay-2" data-scroll-reveal>
        <span>View All</span>
        <svg width="16" height="10" viewBox="0 0 16 10" fill="none">
          <path d="M0 5H15M15 5L11 1M15 5L11 9" stroke="currentColor" stroke-width="1"/>
        </svg>
      </a>
    {% endif %}
  </div>

  {%- assign source_collection = collections[section.settings.collection] -%}

  <div class="product-grid fade-up delay-2" data-scroll-reveal>
    {% if source_collection != blank %}
      {% for product in source_collection.products limit: section.settings.product_limit %}
        <div class="product-card">
          <div class="product-card__media">

            {% if product.available == false %}
              <span class="product-card__badge">Sold Out</span>
            {% elsif product.created_at > 'now' | date: '%s' | minus: 2592000 | date: '%Y-%m-%d' %}
              <span class="product-card__badge">New</span>
            {% endif %}

            <a href="{{ product.url }}">
              {% if product.featured_image != blank %}
                <img class="product-card__img"
                     src="{{ product.featured_image | img_url: '700x' }}"
                     alt="{{ product.featured_image.alt | default: product.title }}"
                     loading="lazy">
                {% if product.images[1] != blank %}
                  <img class="product-card__img-alt"
                       src="{{ product.images[1] | img_url: '700x' }}"
                       alt="{{ product.title }} alternate"
                       loading="lazy">
                {% endif %}
              {% else %}
                <div style="position:absolute;inset:0;background:var(--c-beige-dark);"></div>
              {% endif %}
            </a>

            <button class="product-card__wish-btn" aria-label="Add to wishlist">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>

            <div class="product-card__actions">
              <a href="{{ product.url }}?add_to_cart=true" class="product-card__add-btn">
                {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
              </a>
            </div>
          </div>

          <div class="product-card__info">
            <p class="product-card__category">{{ product.type | default: product.tags.first }}</p>
            <a href="{{ product.url }}">
              <h3 class="product-card__name">{{ product.title }}</h3>
            </a>
            <p class="product-card__price">
              {{ product.price | money_without_trailing_zeros }}
            </p>
          </div>
        </div>
      {% endfor %}

    {% else %}
      {% comment %} Editor placeholder cards {% endcomment %}
      {% for i in (1..section.settings.product_limit) %}
        <div class="product-card">
          <div class="product-card__media">
            <div style="position:absolute;inset:0;background:linear-gradient(160deg,var(--c-beige) 0%,var(--c-beige-dark) 100%);"></div>
          </div>
          <div class="product-card__info">
            <p class="product-card__category">Category</p>
            <h3 class="product-card__name">Product Name</h3>
            <p class="product-card__price">€ 0.00</p>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  {% if section.settings.show_view_all %}
    <div class="arrivals-footer fade-up" data-scroll-reveal>
      <a href="{{ section.settings.view_all_url | default: '/collections/all' }}" class="btn-luxury">
        <span>{{ section.settings.view_all_label | default: 'View All New Arrivals' }}</span>
      </a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    { "type": "text",       "id": "eyebrow",        "label": "Eyebrow",       "default": "Just Arrived" },
    { "type": "text",       "id": "heading",         "label": "Heading",       "default": "New Arrivals" },
    { "type": "collection", "id": "collection",      "label": "Source collection" },
    { "type": "range",      "id": "product_limit",   "label": "Products to show",
      "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "range",      "id": "columns",         "label": "Columns on desktop",
      "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "header",     "content": "View All" },
    { "type": "checkbox",   "id": "show_view_all",   "label": "Show 'View All' button", "default": true },
    { "type": "text",       "id": "view_all_label",  "label": "Button label",  "default": "View All New Arrivals" },
    { "type": "url",        "id": "view_all_url",    "label": "Button URL" }
  ],
  "presets": [{ "name": "New Arrivals" }]
}
{% endschema %}
