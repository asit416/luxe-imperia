<section class="split-campaign" style="background:{{ section.settings.background_color }};">
  <div class="split-campaign__grid">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'panel' -%}
          <div class="split-campaign__panel" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.cta_url }}" class="split-campaign__panel-link">
              <div class="split-campaign__media">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 1000 }}"
                       srcset="{{ block.settings.image | image_url: width: 600 }} 600w,
                               {{ block.settings.image | image_url: width: 1000 }} 1000w"
                       sizes="(max-width: 768px) 100vw, 50vw"
                       alt="{{ block.settings.title | escape }}"
                       loading="lazy">
                {%- else -%}
                  <div class="split-campaign__placeholder">
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}
                <div class="split-campaign__overlay" style="--overlay:{{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>
              </div>
              <div class="split-campaign__content">
                {%- if block.settings.label != blank -%}
                  <p class="split-campaign__label">{{ block.settings.label }}</p>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="split-campaign__title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.cta_text != blank -%}
                  <span class="split-campaign__cta">{{ block.settings.cta_text }} →</span>
                {%- endif -%}
              </div>
            </a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<style>
  /* ============================================
     SPLIT CAMPAIGN — DUAL / TRIPLE PANELS
  ============================================ */
  .split-campaign { overflow: hidden; }

  .split-campaign__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .split-campaign__panel { position: relative; }

  .split-campaign__panel-link {
    display: block;
    position: relative;
    overflow: hidden;
  }

  .split-campaign__panel-link:hover { opacity: 1; }

  .split-campaign__media {
    position: relative;
    aspect-ratio: 2/3;
    overflow: hidden;
  }

  .split-campaign__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease-luxury);
  }

  .split-campaign__panel:hover .split-campaign__media img {
    transform: scale(1.06);
  }

  .split-campaign__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-cream);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .split-campaign__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,var(--overlay, 0.2));
    transition: background var(--transition-slow);
  }

  .split-campaign__panel:hover .split-campaign__overlay {
    background: rgba(0,0,0,calc(var(--overlay, 0.2) + 0.1));
  }

  .split-campaign__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40px 36px;
    color: white;
    text-align: center;
  }

  .split-campaign__label {
    font-family: var(--font-sans);
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 10px;
    opacity: 0.8;
  }

  .split-campaign__title {
    font-family: var(--font-serif);
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 300;
    letter-spacing: 0.04em;
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .split-campaign__cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(255,255,255,0.6);
    padding-bottom: 3px;
    transition: border-color var(--transition-fast), letter-spacing var(--transition-fast);
  }

  .split-campaign__panel:hover .split-campaign__cta {
    border-color: white;
    letter-spacing: 0.25em;
  }

  @media (max-width: 768px) {
    .split-campaign__grid { grid-template-columns: 1fr; }
    .split-campaign__media { aspect-ratio: 4/5; }
  }
</style>

{% schema %}
{
  "name": "Split Campaign",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    {"type":"color","id":"background_color","label":"Background color","default":"#0a0a0a"}
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Campaign Panel",
      "settings": [
        {"type":"image_picker","id":"image","label":"Panel image"},
        {"type":"range","id":"overlay_opacity","label":"Overlay opacity","min":0,"max":60,"step":5,"default":20},
        {"type":"text","id":"label","label":"Label","default":"Women"},
        {"type":"text","id":"title","label":"Title","default":"New Season"},
        {"type":"text","id":"cta_text","label":"CTA text","default":"Shop Now"},
        {"type":"url","id":"cta_url","label":"Panel link"}
      ]
    }
  ],
  "presets": [
    {
      "name": "Split Campaign",
      "blocks": [
        {"type":"panel","settings":{"label":"Women","title":"The New Collection"}},
        {"type":"panel","settings":{"label":"Men","title":"A Modern Wardrobe"}}
      ]
    }
  ]
}
{% endschema %}
