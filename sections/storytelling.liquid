<section class="storytelling" style="background:{{ section.settings.background_color }};">
  <div class="storytelling__inner {{ section.settings.alignment }}">
    <div class="container">
      <div class="storytelling__content reveal">
        {%- if section.settings.label != blank -%}
          <p class="storytelling__label">{{ section.settings.label }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="storytelling__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <div class="storytelling__body">{{ section.settings.body }}</div>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url }}"
             class="btn-luxury {% if section.settings.background_color == '#0a0a0a' or section.settings.background_color == '#000000' %}btn-luxury--light{% else %}btn-luxury--dark{% endif %}">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- if section.settings.show_divider -%}
    <div class="storytelling__divider">
      <span class="divider-ornament">&#10022;</span>
    </div>
  {%- endif -%}
</section>

<style>
  /* ============================================
     STORYTELLING / EDITORIAL PROSE SECTION
  ============================================ */
  .storytelling {
    overflow: hidden;
  }

  .storytelling__inner {
    padding: 120px 0;
  }

  .storytelling__inner.align-center {
    text-align: center;
  }

  .storytelling__inner.align-center .storytelling__body {
    margin: 0 auto;
  }

  .storytelling__inner.align-left .storytelling__content {
    max-width: 680px;
  }

  .storytelling__inner.align-right {
    text-align: right;
  }

  .storytelling__inner.align-right .storytelling__content {
    max-width: 680px;
    margin-left: auto;
  }

  .storytelling__label {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .storytelling__inner.align-center .storytelling__label {
    justify-content: center;
  }

  .storytelling__label::before,
  .storytelling__label::after {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--color-gold);
    flex-shrink: 0;
  }

  .storytelling__inner.align-left .storytelling__label::before,
  .storytelling__inner.align-right .storytelling__label::after {
    display: none;
  }

  .storytelling__title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5vw, 80px);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: 0.02em;
    margin-bottom: 32px;
  }

  .storytelling__body {
    max-width: 560px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 300;
    line-height: 2;
    color: var(--color-text-muted);
    margin-bottom: 40px;
  }

  .storytelling__body p + p { margin-top: 16px; }

  .storytelling__divider {
    text-align: center;
    padding: 0 0 80px;
    color: var(--color-gold);
    font-size: 18px;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .storytelling__inner { padding: 80px 0; }
    .storytelling__inner.align-right { text-align: left; }
    .storytelling__inner.align-right .storytelling__content { margin-left: 0; }
    .storytelling__label { justify-content: flex-start !important; }
    .storytelling__label::before { display: none !important; }
  }
</style>

{% schema %}
{
  "name": "Storytelling",
  "tag": "section",
  "settings": [
    {"type":"color","id":"background_color","label":"Background color","default":"#fafaf8"},
    {"type":"select","id":"alignment","label":"Text alignment","options":[
      {"value":"align-center","label":"Center"},
      {"value":"align-left","label":"Left"},
      {"value":"align-right","label":"Right"}
    ],"default":"align-center"},
    {"type":"text","id":"label","label":"Label text","default":"Our Heritage"},
    {"type":"text","id":"title","label":"Headline","default":"Crafted with Intention,\nWorn with Purpose"},
    {"type":"richtext","id":"body","label":"Body text","default":"<p>Born from a dedication to uncompromising quality, each piece in our collection represents the finest in contemporary luxury. We believe that fashion is not merely clothing — it is the language through which identity is expressed.</p>"},
    {"type":"text","id":"cta_label","label":"Button label","default":"Discover Our Story"},
    {"type":"url","id":"cta_url","label":"Button link"},
    {"type":"checkbox","id":"show_divider","label":"Show decorative divider","default":false}
  ],
  "presets": [{"name":"Storytelling"}]
}
{% endschema %}
